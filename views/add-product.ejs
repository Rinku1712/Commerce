<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Add Product | Seller Panel</title>
</head>
<body class="bg-gray-50">
    <div class="max-w-md mx-auto mt-10 bg-white p-6 rounded shadow-md">
        <h2 class="text-xl font-bold text-gray-700 mb-4">🚀 Seller Panel: Add Product</h2>
        <form action="/products/add" method="POST" enctype="multipart/form-data" class="space-y-4">
            <div>
                <label class="block text-sm font-medium">Product Name</label>
                <input type="text" name="name" class="w-full p-2 border rounded" required>
            </div>
            <div>
                <label class="block text-sm font-medium">Price (₹)</label>
                <input type="number" name="price" class="w-full p-2 border rounded" required>
            </div>
            <div>
                <label class="block text-sm font-medium">Product Image</label>
                <input type="file" name="productImage" class="w-full p-1 border rounded" required>
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded font-bold">Upload Product</button>
        </form>
    </div>
</body>
</html>