<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <title>SRZONE</title>
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-[#2874f0] sticky top-0 z-50 text-white py-3 px-4 md:px-12 shadow-md">
        <div class="max-w-7xl mx-auto flex flex-col lg:flex-row justify-between items-center gap-4">
            
            <div class="flex items-center space-x-6 shrink-0 w-full lg:w-auto justify-between lg:justify-start">
                <a href="/dashboard" class="text-xl font-bold italic tracking-wide hover:opacity-90">
                    SR<span class="text-[#ffe500] font-black not-italic">ZONE</span>
                </a>
                <div class="flex items-center space-x-4 text-xs md:text-sm">
                    <a href="/products/wishlist" class="hover:text-yellow-300 transition flex items-center gap-1"><i class="fa fa-heart text-red-400"></i> Wishlist</a>
                    <a href="/products/cart" class="hover:text-yellow-300 transition flex items-center gap-1"><i class="fa fa-shopping-cart text-yellow-300"></i> My Cart</a>
                    <a href="/products/orders" class="hover:text-yellow-300 transition flex items-center gap-1"><i class="fa fa-box text-orange-300"></i> Orders/Sales</a>
                </div>
            </div>

            <div class="w-full lg:w-2/5 relative">
                <div class="relative">
                    <input type="text" id="megaSearchInput" onkeyup="handleSearchInput()" placeholder="Search for products, brands and more..." class="w-full py-2 px-4 pr-10 text-black text-sm rounded shadow-sm focus:outline-none focus:ring-2 focus:ring-yellow-400" autocomplete="off">
                    <div class="absolute right-3 top-2.5 text-[#2874f0]">
                        <i class="fa fa-search cursor-pointer"></i>
                    </div>
                </div>
                
                <div id="suggestionBox" class="absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded shadow-xl max-h-60 overflow-y-auto z-50 hidden text-black text-sm divide-y">
                    </div>
            </div>

            <div class="flex items-center space-x-4 text-sm font-semibold w-full lg:w-auto justify-between lg:justify-end shrink-0">
                <div class="flex items-center space-x-1 bg-white/10 px-3 py-1.5 rounded border border-white/20">
                    <i class="fa fa-user-circle text-xl text-[#ffe500]"></i>
                    <span class="capitalize text-xs md:text-sm"><%= user.name %> (<%= user.role %>)</span>
                </div>

                <% if(user.role === 'seller') { %>
                    <a href="/products/add" class="bg-[#ffe500] hover:bg-[#fcd34d] text-black px-3 py-1.5 rounded font-bold text-xs md:text-sm transition flex items-center gap-1 shadow animate-pulse">
                        <i class="fa-solid fa-plus-circle"></i> Add Product
                    </a>
                <% } %>

                <a href="/logout" class="bg-red-500 hover:bg-red-600 px-3 py-1.5 rounded text-xs transition font-medium flex items-center gap-1">
                    <i class="fa-solid fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="bg-white shadow-sm border-b hidden md:block py-3 px-8">
        <div class="max-w-6xl mx-auto flex justify-between text-center text-xs font-bold text-gray-700">
            <div class="cursor-pointer hover:text-[#2874f0]"><i class="fa-solid fa-bolt text-lg text-yellow-500 block mb-1"></i>Top Offers</div>
            <div class="cursor-pointer hover:text-[#2874f0]"><i class="fa-solid fa-mobile-screen text-lg text-blue-500 block mb-1"></i>Mobiles</div>
            <div class="cursor-pointer hover:text-[#2874f0]"><i class="fa-solid fa-laptop text-lg text-indigo-500 block mb-1"></i>Electronics</div>
            <div class="cursor-pointer hover:text-[#2874f0]"><i class="fa-solid fa-shirt text-lg text-green-500 block mb-1"></i>Fashion</div>
            <div class="cursor-pointer hover:text-[#2874f0]"><i class="fa-solid fa-couch text-lg text-amber-600 block mb-1"></i>Home & Furniture</div>
            <div class="cursor-pointer hover:text-[#2874f0]"><i class="fa-solid fa-gem text-lg text-pink-500 block mb-1"></i>Jewelry</div>
        </div>
    </div>

    <main class="max-w-7xl mx-auto p-4 md:p-8">
        
        <div class="mb-6">
            <div class="bg-gradient-to-r from-purple-900 via-indigo-800 to-blue-900 text-white p-6 rounded-lg shadow-lg flex flex-col md:flex-row justify-between items-center relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 opacity-10 text-[120px] font-black"><i class="fa fa-bolt"></i></div>
                <div class="mb-4 md:mb-0">
                    <span class="bg-amber-500 text-black text-[10px] font-black px-2 py-0.5 rounded-full tracking-wider uppercase shadow">Live Mega Event</span>
                    <h1 class="text-2xl md:text-3xl font-black mt-1 text-yellow-400">BIG BILLION DAYS ARE LIVE!</h1>
                    <p class="text-xs text-gray-200 mt-1">Get instant 10% cashbacks via mock credit gates. Free delivery extended till next week!</p>
                </div>
                <div class="flex gap-4">
                    <div class="bg-white/10 backdrop-blur text-center p-3 rounded border border-white/20"><span class="block text-xl font-bold text-yellow-300">80% OFF</span><span class="text-[10px] uppercase text-gray-300">Electronics</span></div>
                    <div class="bg-white/10 backdrop-blur text-center p-3 rounded border border-white/20"><span class="block text-xl font-bold text-yellow-300">No Cost</span><span class="text-[10px] uppercase text-gray-300">Card EMI</span></div>
                </div>
            </div>
        </div>

        <div class="flex justify-between items-center border-b pb-4 mb-6 bg-white p-4 rounded shadow-sm">
            <h2 class="text-xl font-extrabold text-gray-800">⚡ Trending Catalog Deals</h2>
        </div>

        <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% if(products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="product-card bg-white rounded-lg p-4 border border-gray-200 hover:shadow-2xl transition-all duration-300 flex flex-col justify-between relative group">
                        
                        <form action="/products/wishlist/add/<%= product.id %>" method="POST" class="absolute top-3 right-3 z-10">
                            <button type="submit" class="bg-white p-2 rounded-full shadow hover:bg-gray-100 text-gray-400 hover:text-red-500 transition">
                                <i class="fa fa-heart"></i>
                            </button>
                        </form>

                        <span class="absolute top-3 left-3 bg-[#2874f0] text-white text-[9px] font-black px-2 py-0.5 rounded shadow z-10">F-Assured <i class="fa fa-check text-yellow-300"></i></span>

                        <div class="h-48 w-full bg-gray-50 rounded flex items-center justify-center p-2 mb-4">
                            <img src="<%= product.image %>" class="max-h-full max-w-full object-contain" alt="<%= product.name %>">
                        </div>

                        <div>
                            <h3 class="product-name font-bold text-gray-800 text-base truncate"><%= product.name %></h3>
                            <div class="flex items-baseline space-x-2 pt-1">
                                <span class="text-[#388e3c] font-black text-xl">₹<%= product.price %></span>
                                <span class="text-xs text-gray-400 line-through">₹<%= parseInt(product.price) + 499 %></span>
                            </div>
                        </div>

                        <div class="mt-4 pt-2 border-t flex flex-col gap-2">
                            <form action="/products/cart/add/<%= product.id %>" method="POST">
                                <button type="submit" class="w-full bg-[#ffe500] hover:bg-yellow-400 text-black font-bold py-2 rounded text-sm transition shadow flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-cart-plus"></i> Add to Cart
                                </button>
                            </form>
                            <form action="/products/buy/<%= product.id %>" method="POST">
                                <button type="submit" class="w-full bg-[#ff9f00] hover:bg-[#f39200] text-white font-bold py-2 rounded text-sm transition shadow flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-bolt"></i> Instant Buy
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full bg-white border rounded-lg text-center p-12 w-full">
                    <p class="text-gray-400">No active products inside the catalogue file stream.</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        // Trigger hota hai har keyup event par autocomplete + dynamic card filtering ke liye
        function handleSearchInput() {
            const input = document.getElementById('megaSearchInput').value.toLowerCase();
            const cards = document.getElementsByClassName('product-card');
            const suggestionBox = document.getElementById('suggestionBox');
            
            // Clean up old elements inside dropdown
            suggestionBox.innerHTML = '';
            
            if (input.trim() === '') {
                suggestionBox.classList.add('hidden');
                // Display all products back if input is fully cleared
                for (let i = 0; i < cards.length; i++) cards[i].style.display = "";
                return;
            }

            let matchCount = 0;

            for (let i = 0; i < cards.length; i++) {
                const nameElement = cards[i].getElementsByClassName('product-name')[0];
                if (nameElement) {
                    const nameText = nameElement.textContent || nameElement.innerText;
                    
                    if (nameText.toLowerCase().indexOf(input) > -1) {
                        cards[i].style.display = ""; // Render matched card
                        matchCount++;
                        
                        // Dropdown mein dynamic suggestion row item append karo
                        const div = document.createElement('div');
                        div.className = "p-3 hover:bg-gray-100 cursor-pointer flex items-center gap-2 transition";
                        div.innerHTML = `<i class="fa fa-history text-gray-400 text-xs"></i> <span>${nameText}</span>`;
                        
                        // Sugggestion selection behavior handle event
                        div.onclick = function() {
                            document.getElementById('megaSearchInput').value = nameText;
                            suggestionBox.classList.add('hidden');
                            filterCardsDirect(nameText.toLowerCase());
                        };
                        suggestionBox.appendChild(div);
                    } else {
                        cards[i].style.display = "none"; // Hide card if not matched
                    }
                }
            }

            // Suggestions drop overlay status configure karo basis matches
            if (matchCount > 0) {
                suggestionBox.classList.remove('hidden');
            } else {
                suggestionBox.innerHTML = `<div class="p-3 text-gray-400 text-center italic">No suggestions found</div>`;
                suggestionBox.classList.remove('hidden');
            }
        }

        // Helper event for specific dropdown string click
        function filterCardsDirect(matchedString) {
            const cards = document.getElementsByClassName('product-card');
            for (let i = 0; i < cards.length; i++) {
                const nameElement = cards[i].getElementsByClassName('product-name')[0];
                if (nameElement) {
                    const nameText = nameElement.textContent || nameElement.innerText;
                    cards[i].style.display = (nameText.toLowerCase().indexOf(matchedString) > -1) ? "" : "none";
                }
            }
        }

        // Dropdown pop close out area listener clicks
        document.addEventListener('click', function(e) {
            const box = document.getElementById('suggestionBox');
            const input = document.getElementById('megaSearchInput');
            if (e.target !== box && e.target !== input) {
                box.classList.add('hidden');
            }
        });
    </script>
</body>
</html>