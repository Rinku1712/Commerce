<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Login | SRZONE</title>
</head>
<body class="bg-gray-100 flex items-center justify-center h-screen">
    <div class="bg-white p-8 rounded-lg shadow-lg w-96 border-t-4 border-blue-500">
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-blue-600">SRZONE</h1>
        </div>
        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-sm font-semibold">Email</label>
                <input type="email" name="email" class="w-full p-2 border border-gray-500 rounded mt-1" required>
            </div>
            <div>
                <label class="block text-sm font-semibold">Password</label>
                <input type="password" name="password" class="w-full p-2 border border-gray-500 rounded mt-1" required>
            </div>
            <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-bold py-2 rounded transition">Login</button>
        </form>
        <p class="text-xs text-center mt-4">New here? <a href="/signup" class="text-blue-500 hover:underline">Create an account</a></p>
        <a href="/forgot-password" class="text-xs text-center block text-blue-500 hover:underline">Forgot Password?</a>
    </div>
</body>
</html>