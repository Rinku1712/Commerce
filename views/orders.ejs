<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <title>Activity Tracker & Order Manager</title>
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-[#2874f0] text-white py-4 px-4 md:px-12 shadow-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/dashboard" class="text-xl font-bold italic tracking-wide hover:opacity-90">
                <i class="fa fa-arrow-left text-sm mr-2"></i> SR<span class="text-[#ffe500] font-black not-italic">ZONE</span>
            </a>
            <span class="text-xs md:text-sm font-semibold bg-white/10 px-3 py-1 rounded border border-white/25">
                <i class="fa-solid fa-truck-fast text-yellow-300"></i> Live Logistics Center
            </span>
        </div>
    </nav>

    <div class="max-w-5xl mx-auto mt-6 p-4">
        
        <% if(user.role === 'seller') { %>
            <div class="bg-emerald-600 text-white p-6 rounded-lg shadow-md mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-black tracking-tight">📈 Seller Merchant Revenue & Logistics</h2>
                    <p class="text-xs text-emerald-100 mt-1">Control order workflow status, modify transit locations, and track incoming dispatch orders.</p>
                </div>
                <div class="bg-white/10 backdrop-blur px-4 py-2 rounded text-left border border-white/20 shrink-0 w-full sm:w-auto">
                    <span class="text-[10px] uppercase text-emerald-200 block font-bold tracking-wider">Total Sales Inbound</span>
                    <span class="text-2xl font-black text-yellow-300"><%= orders.length %> Records</span>
                </div>
            </div>
        <% } else { %>
            <div class="bg-gradient-to-r from-blue-900 to-indigo-950 text-white p-6 rounded-lg shadow-md mb-6">
                <h2 class="text-2xl font-black tracking-tight">📦 Your Live Shipment Tracker Ledger</h2>
                <p class="text-xs text-blue-200 mt-1">Real-time delivery progress updates managed directly by verified platform vendors.</p>
            </div>
        <% } %>

        <div class="space-y-6">
            <% if(orders && orders.length > 0) { %>
                <% orders.forEach(order => { %>
                    <div class="bg-white shadow rounded-lg p-5 md:p-6 border border-gray-200 hover:border-gray-300 transition-all duration-300">
                        
                        <div class="flex flex-col sm:flex-row justify-between border-b pb-4 mb-4 items-start sm:items-center gap-2">
                            <div>
                                <h4 class="font-extrabold text-gray-800 text-base md:text-lg tracking-tight"><%= order.productName %></h4>
                                <div class="flex flex-wrap gap-2 text-xs text-gray-400 mt-1">
                                    <span>Order ID: <span class="font-mono text-gray-600 font-black bg-gray-100 px-1 py-0.5 rounded"><%= order.orderId %></span></span>
                                    <span>|</span>
                                    <span>Placed On: <span class="text-gray-600 font-semibold"><%= order.date %></span></span>
                                </div>
                            </div>
                            <div class="shrink-0">
                                <span class="text-xl font-black text-[#388e3c]">₹<%= order.price %></span>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-center py-2">
                            
                            <div class="flex items-center space-x-4">
                                <div class="w-20 h-20 bg-gray-50 border p-1 rounded flex items-center justify-center overflow-hidden shrink-0 shadow-sm">
                                    <img src="<%= order.image %>" class="max-h-full max-w-full object-contain" alt="">
                                </div>
                                <div class="min-w-0">
                                    <span class="text-[10px] font-bold text-gray-400 block uppercase tracking-wider">Current Station Node</span>
                                    <span class="text-xs font-bold text-indigo-700 bg-indigo-50 border border-indigo-200 px-2.5 py-1 rounded-md inline-flex items-center gap-1 mt-1 max-w-full truncate">
                                        <i class="fa fa-map-marker-alt text-red-500 animate-bounce"></i> <%= order.currentLocation || 'Warehouse Hub' %>
                                    </span>
                                </div>
                            </div>

                            <div class="lg:col-span-2 bg-gray-50 p-4 rounded-lg border border-gray-100">
                                <div class="flex justify-between items-center relative w-full px-2">
                                    
                                    <% 
                                        let percent = "0%";
                                        if(order.status === "Ordered") percent = "0%";
                                        if(order.status === "Dispatched") percent = "33.33%";
                                        if(order.status === "Out for Delivery") percent = "66.66%";
                                        if(order.status === "Delivered") percent = "100%";
                                    %>
                                    
                                    <div class="absolute left-6 right-6 top-3 h-1 bg-gray-200 z-0">
                                        <div class="h-full bg-green-500 transition-all duration-500" style="width: <%= percent %>"></div>
                                    </div>

                                    <div class="text-center z-10 flex flex-col items-center">
                                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm <%= ['Ordered','Dispatched','Out for Delivery','Delivered'].includes(order.status) ? 'bg-green-500 text-white' : 'bg-gray-300 text-gray-600' %>">
                                            <i class="fa fa-check text-[8px]"></i>
                                        </div>
                                        <span class="text-[10px] font-bold text-gray-600 mt-1">Ordered</span>
                                    </div>

                                    <div class="text-center z-10 flex flex-col items-center">
                                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm <%= ['Dispatched','Out for Delivery','Delivered'].includes(order.status) ? 'bg-green-500 text-white' : 'bg-gray-300 text-gray-600' %>">
                                            <%= ['Dispatched','Out for Delivery','Delivered'].includes(order.status) ? '✓' : '2' %>
                                        </div>
                                        <span class="text-[10px] font-bold text-gray-600 mt-1">Dispatched</span>
                                    </div>

                                    <div class="text-center z-10 flex flex-col items-center">
                                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm <%= ['Out for Delivery','Delivered'].includes(order.status) ? 'bg-green-500 text-white' : 'bg-gray-300 text-gray-600' %>">
                                            <%= ['Out for Delivery','Delivered'].includes(order.status) ? '✓' : '3' %>
                                        </div>
                                        <span class="text-[10px] font-bold text-gray-600 mt-1">Out For Delivery</span>
                                    </div>

                                    <div class="text-center z-10 flex flex-col items-center">
                                        <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold shadow-sm <%= order.status === 'Delivered' ? 'bg-green-500 text-white' : 'bg-gray-300 text-gray-600' %>">
                                            <%= order.status === 'Delivered' ? '✓' : '4' %>
                                        </div>
                                        <span class="text-[10px] font-bold text-gray-600 mt-1">Delivered</span>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <% if(user.role === 'seller') { %>
                            <div class="mt-4 pt-4 border-t bg-emerald-50/40 p-4 rounded-lg border border-emerald-100/80">
                                <h5 class="text-xs font-bold uppercase text-emerald-800 tracking-wider mb-2.5 flex items-center gap-1">
                                    <i class="fa fa-sliders-h"></i> Merchant Logistics Deployment Controls
                                </h5>
                                
                                <form action="/products/order/update-tracker" method="POST" class="flex flex-col sm:flex-row gap-4 items-end w-full">
                                    <input type="hidden" name="orderId" value="<%= order.orderId %>">
                                    
                                    <div class="w-full sm:w-1/3">
                                        <label class="block text-[10px] font-bold text-gray-500 mb-1 uppercase tracking-wide">Logistics Dispatch Stage</label>
                                        <select name="status" class="w-full p-2 border border-gray-300 bg-white rounded text-xs font-bold text-gray-700 focus:outline-none focus:border-emerald-500">
                                            <option value="Ordered" <%= order.status === 'Ordered' ? 'selected' : '' %>>1. Order Confirmed</option>
                                            <option value="Dispatched" <%= order.status === 'Dispatched' ? 'selected' : '' %>>2. Dispatched / Left Warehouse</option>
                                            <option value="Out for Delivery" <%= order.status === 'Out for Delivery' ? 'selected' : '' %>>3. Out for Delivery</option>
                                            <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>4. Marked as Delivered</option>
                                        </select>
                                    </div>

                                    <div class="w-full sm:w-1/3">
                                        <label class="block text-[10px] font-bold text-gray-500 mb-1 uppercase tracking-wide">Current Hub Station Location</label>
                                        <input type="text" name="currentLocation" value="<%= order.currentLocation %>" placeholder="e.g. Panipat Delivery Hub" class="w-full p-2 border border-gray-300 rounded text-xs font-semibold text-gray-700 focus:outline-none focus:border-emerald-500" required>
                                    </div>

                                    <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white font-bold px-5 py-2 rounded text-xs transition duration-200 shadow hover:shadow-md shrink-0 w-full sm:w-auto uppercase tracking-wider">
                                        Update Tracking Logs
                                    </button>
                                </form>
                            </div>
                        <% } %>

                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-center bg-white border border-gray-200 p-16 rounded-lg text-gray-400 shadow-sm">
                    <div class="bg-gray-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fa fa-map-marked-alt text-2xl text-gray-400"></i>
                    </div>
                    <h3 class="text-gray-700 font-bold text-base">No active shipments in pipeline log</h3>
                    <p class="text-xs text-gray-400 mt-1 max-w-sm mx-auto">There are no transaction arrays registered inside the file storage tracker system yet.</p>
                    <a href="/dashboard" class="mt-4 inline-block bg-[#2874f0] text-white font-bold text-xs px-4 py-2 rounded shadow hover:bg-blue-600 transition">Return to Store</a>
                </div>
            <% } %>
        </div>
    </div>

    <div class="h-12"></div>
</body>
</html>