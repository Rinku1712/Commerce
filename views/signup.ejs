<!DOCTYPE html>
<html lang="en">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Signup | Register</title>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center py-8">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl border-t-4 border-blue-500">
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-blue-600">Create Account</h1>
            <p class="text-sm text-gray-500 mt-2">Add your basic details and a short profile section before verification.</p>
        </div>
        <form action="/signup" method="POST" class="space-y-4">
            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold">Full Name</label>
                    <input type="text" name="name" class="w-full p-2 border rounded mt-1" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold">Email</label>
                    <input type="email" name="email" class="w-full p-2 border rounded mt-1" required>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold">Password</label>
                    <input type="password" name="password" class="w-full p-2 border rounded mt-1" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold">Join As</label>
                    <select name="role" class="w-full p-2 border rounded mt-1 bg-white">
                        <option value="user">Buyer / Customer</option>
                        <option value="seller">Seller / Vendor</option>
                    </select>
                </div>
            </div>

            <div class="border rounded-lg p-4 bg-gray-50">
                <h2 class="text-sm font-semibold text-gray-700 mb-3">Profile Section</h2>
                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold">Phone Number</label>
                        <input type="tel" name="phone" class="w-full p-2 border rounded mt-1" placeholder="e.g. 9876543210">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold">Address</label>
                        <input type="text" name="address" class="w-full p-2 border rounded mt-1" placeholder="City / State">
                    </div>
                </div>
                <div class="mt-4">
                    <label class="block text-sm font-semibold">Bio</label>
                    <textarea name="bio" rows="3" class="w-full p-2 border rounded mt-1" placeholder="Tell us a little about yourself"></textarea>
                </div>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 rounded transition">Send OTP & Register</button>
        </form>
        <p class="text-xs text-center mt-4">Already have an account? <a href="/login" class="text-blue-500 hover:underline">Login</a></p>
    </div>
</body>
</html>